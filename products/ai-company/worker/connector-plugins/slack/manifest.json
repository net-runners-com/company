{
  "id": "slack",
  "version": "1.0.0",
  "type": "webhook",
  "display": {
    "name": { "en": "Slack", "ja": "Slack" },
    "description": { "en": "Connect Slack workspace for team communication", "ja": "Slackワークスペースを接続してチーム連携を自動化" },
    "color": "#4A154B",
    "bgColor": "#4A154B15",
    "iconFile": "icon.svg"
  },
  "fields": [
    { "key": "botToken", "label": { "en": "Bot Token", "ja": "ボットトークン" }, "type": "password", "required": true },
    { "key": "channelId", "label": { "en": "Channel ID", "ja": "チャンネルID" }, "type": "text", "required": true }
  ],
  "auth": { "type": "webhook" },
  "agent": {
    "script": null,
    "envMapping": { "SLACK_BOT_TOKEN": "botToken", "SLACK_CHANNEL_ID": "channelId" }
  }
}
