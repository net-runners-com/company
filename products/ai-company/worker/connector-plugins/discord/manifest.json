{
  "id": "discord",
  "version": "1.0.0",
  "type": "webhook",
  "display": {
    "name": { "en": "Discord", "ja": "Discord" },
    "description": { "en": "Connect Discord server for community management", "ja": "Discordサーバーを接続してコミュニティ管理を自動化" },
    "color": "#5865F2",
    "bgColor": "#5865F215",
    "iconFile": "icon.svg"
  },
  "fields": [
    { "key": "botToken", "label": { "en": "Bot Token", "ja": "ボットトークン" }, "type": "password", "required": true },
    { "key": "serverId", "label": { "en": "Server ID", "ja": "サーバーID" }, "type": "text", "required": true },
    { "key": "channelId", "label": { "en": "Channel ID", "ja": "チャンネルID" }, "type": "text", "required": true }
  ],
  "auth": { "type": "webhook" },
  "agent": {
    "script": null,
    "envMapping": { "DISCORD_BOT_TOKEN": "botToken", "DISCORD_SERVER_ID": "serverId", "DISCORD_CHANNEL_ID": "channelId" }
  }
}
