{
  "id": "line",
  "version": "1.0.0",
  "type": "webhook",
  "display": {
    "name": { "en": "LINE", "ja": "LINE" },
    "description": { "en": "Connect LINE Official Account for customer messaging", "ja": "LINE公式アカウントを接続して顧客対応・通知を自動化" },
    "color": "#06C755",
    "bgColor": "#06C75515",
    "iconFile": "icon.svg"
  },
  "fields": [
    { "key": "channelId", "label": { "en": "Channel ID", "ja": "チャンネルID" }, "type": "text", "required": true },
    { "key": "channelSecret", "label": { "en": "Secret Key", "ja": "シークレットキー" }, "type": "text", "required": true },
    { "key": "accessToken", "label": { "en": "Access Token", "ja": "アクセストークン" }, "type": "password", "required": true }
  ],
  "auth": { "type": "webhook" },
  "agent": {
    "script": "/workspace/features/line/line-agent.sh",
    "envMapping": { "LINE_CHANNEL_SECRET": "channelSecret", "LINE_ACCESS_TOKEN": "accessToken", "LINE_CHANNEL_ID": "channelId" }
  }
}
