{
  "version": 3,
  "pages404": true,
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [],
  "dynamicRoutes": [
    {
      "page": "/api/data/[collection]",
      "regex": "^/api/data/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPcollection": "nxtPcollection"
      },
      "namedRegex": "^/api/data/(?<nxtPcollection>[^/]+?)(?:/)?$"
    },
    {
      "page": "/api/data/[collection]/[id]",
      "regex": "^/api/data/([^/]+?)/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPcollection": "nxtPcollection",
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/api/data/(?<nxtPcollection>[^/]+?)/(?<nxtPid>[^/]+?)(?:/)?$"
    },
    {
      "page": "/employee/[id]",
