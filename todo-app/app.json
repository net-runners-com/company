{
  "expo": {
    "name": "FocusDrop",
    "slug": "focusdrop",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "scheme": "focusdrop",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0c1222"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.netrunners.focusdrop"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0c1222"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.netrunners.focusdrop"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router"
    ]
  }
}
